# API server
PORT=4000
DATABASE_URL=postgres://matchhub_user:change-me@localhost:5432/matchhub
SESSION_SECRET=replace-with-a-long-random-secret

# Browser/API hosting
# Comma-separate multiple origins, for example:
# CORS_ORIGIN=https://your-frontend.example.com,https://www.your-frontend.example.com
CORS_ORIGIN=http://localhost:5173
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
TRUST_PROXY=false

# Frontend dev server
FRONTEND_PORT=5173
BASE_PATH=/
API_PROXY_TARGET=http://127.0.0.1:4000

# Optional production admin seed. Used only by `pnpm db:seed`.
ADMIN_USERNAME=
ADMIN_PASSWORD=
ADMIN_DISPLAY_NAME=

# Set to false when you only want to seed ADMIN_USERNAME/ADMIN_PASSWORD.
SEED_TEST_USERS=true
